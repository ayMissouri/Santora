{
	"schemaVersion": 1,
	"id": "santora",
	"version": "${version}",
	"name": "Santora",
	"description": "An in-game music player for Minecraft's own soundtrack. Browse every vanilla track as albums, with play/pause/skip, shuffle, a queue, and crossfade.",
	"authors": ["amissouri"],
	"contact": {},
	"license": "MIT",
	"icon": "assets/santora/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"dev.santora.compat.SantoraEntrypoint"
		]
	},
	"mixins": [
		"santora.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "${minecraft_version}",
		"java": ">=21",
		"fabric": "*"
	}
}
